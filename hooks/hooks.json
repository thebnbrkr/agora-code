{
  "SessionStart": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "agora-code inject --quiet"
        }
      ]
    }
  ],
  "PreCompact": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "agora-code checkpoint --quiet"
        }
      ]
    }
  ],
  "PostToolUse": [
    {
      "matcher": "Write|Edit|MultiEdit",
      "hooks": [
        {
          "type": "command",
          "command": "agora-code scan . --cache --quiet"
        }
      ]
    }
  ]
}
