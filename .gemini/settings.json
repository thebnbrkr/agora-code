{
    "hooks": {
        "SessionStart": [
            {
                "type": "command",
                "command": "agora-code inject --quiet || exit 0"
            }
        ],
        "PreCompact": [
            {
                "type": "command",
                "command": "agora-code checkpoint --quiet"
            }
        ],
        "PostToolUse": [
            {
                "matcher": "Write|Edit|MultiEdit|write_file|replace|edit_file",
                "hooks": [
                    {
                        "type": "command",
                        "command": "agora-code scan . --cache --quiet"
                    },
                    {
                        "type": "command",
                        "command": "agora-code track-diff $GEMINI_TOOL_INPUT_FILE_PATH"
                    }
                ]
            }
        ]
    }
}
