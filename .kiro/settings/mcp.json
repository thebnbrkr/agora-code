{
  "mcpServers": {
    "agora-memory": {
      "command": "/Library/Frameworks/Python.framework/Versions/3.10/bin/agora-code",
      "args": ["memory-server"],
      "autoApprove": [
        "get_session_context",
        "save_checkpoint",
        "store_learning",
        "recall_learnings",
        "complete_session",
        "get_memory_stats",
        "list_sessions",
        "recall_file_history",
        "get_file_symbols",
        "search_symbols",
        "summarize_file",
        "read_file_range",
        "index_file"
      ]
    }
  }
}
